{
  "name": "telegram-ai-bot",
  "version": "1.0.0",
  "description": "Production-grade Telegram AI chatbot powered by NVIDIA AI API",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rimraf dist",
    "precommit": "npm run lint && npm run typecheck && npm run test",
    "docker:build": "docker build -t telegram-ai-bot .",
    "docker:run": "docker run -p 3000:3000 --env-file .env telegram-ai-bot"
  },
  "dependencies": {
    "grammy": "^1.32.0",
    "fastify": "^5.1.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@fastify/helmet": "^12.0.0",
    "@fastify/compress": "^8.0.0",
    "axios": "^1.7.9",
    "zod": "^3.24.1",
    "dotenv": "^16.4.7",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "sql.js": "^1.11.0",
    "uuid": "^11.0.3",
    "p-limit": "^6.2.0",
    "marked": "^15.0.3"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "tsx": "^4.19.2",
    "@types/node": "^22.10.2",

    "@types/uuid": "^10.0.0",
    "eslint": "^9.17.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "vitest": "^2.1.8",
    "rimraf": "^6.0.1",
    "nodemon": "^3.1.9"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
